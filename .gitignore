# Maven compiled output
target/
*.jar
*.war
*.ear

# VS Code internal workspace tracking
.vscode/
.workspace/
*.code-workspace

# Eclipse / IntelliJ files that might be auto-generated
.settings/
.project
.classpath
.idea/
*.iml

# OS generated files
Thumbs.db
.DS_Store

# Test execution reports
test-output/
surefire-reports/

# ==========================================
# 🔐 ENTERPRISE SECURITY & LOCAL ISOLATION
# ==========================================

# Block local environment files containing real passwords
.env
*.env

# Block any local properties overrides or user-specific configs
*.local.properties
src/test/resources/*.local.properties